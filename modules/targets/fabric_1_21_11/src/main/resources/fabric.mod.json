{
  "schemaVersion": 1,
  "id": "linearreader",
  "version": "${version}",
  "name": "LinearReader",
  "description": "A mod that uses .linear compression to reduce the file size of your world.",
  "authors": ["Bugfunbug"],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.bugfunbug.linearreader.LinearReader"],
    "client": ["com.bugfunbug.linearreader.LinearReader"]
  },
  "mixins": ["linearreader.mixins.json"],
  "depends": {
    "fabricloader":  "${fabric_loader_dependency_range}",
    "minecraft":     "${minecraft_dependency_range}",
    "java":          ">=21",
    "fabric-api":    "*"
  }
}
